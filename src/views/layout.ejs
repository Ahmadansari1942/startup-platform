<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <%- include('partials/head') %>
</head>
<body class="font-sans antialiased bg-gray-50 dark:bg-dark-bg text-gray-900 dark:text-dark-text transition-colors duration-300">
    
    <!-- Loading Spinner Overlay -->
    <div id="loading-overlay" class="fixed inset-0 bg-white dark:bg-dark-bg z-50 flex items-center justify-center hidden">
        <div class="text-center">
            <div class="spinner mx-auto mb-4"></div>
            <p class="text-gray-600 dark:text-gray-400">Loading...</p>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- Navigation -->
    <%- include('partials/navbar') %>

    <!-- Flash Messages -->
    <%- include('partials/flash') %>

    <!-- Main Content -->
    <main class="min-h-screen">
        <%- body %>
    </main>

    <!-- Footer -->
    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <script src="/js/dark-mode.js"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/main.js"></script>
    
    <!-- Page specific scripts -->
    <% if (typeof scripts !== 'undefined') { %>
        <%- scripts %>
    <% } %>
</body>
</html>
