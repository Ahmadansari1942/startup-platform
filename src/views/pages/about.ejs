<%- contentFor('body') %>

<section class="pt-24 pb-12 min-h-screen">
  <div class="max-w-7xl mx-auto px-4">
    <h1 class="text-4xl font-bold text-center mb-12 dark:text-white">About <span class="gradient-text">Us</span></h1>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <% team.forEach(member => { %>
        <div class="bg-white dark:bg-dark-card rounded-2xl p-6 shadow-sm hover-card text-center">
          <img src="<%= member.image %>" alt="<%= member.name %>" class="w-24 h-24 rounded-full mx-auto mb-4">
          <h3 class="text-xl font-bold dark:text-white"><%= member.name %></h3>
          <p class="text-blue-600 mb-2"><%= member.role %></p>
          <p class="text-gray-600 dark:text-gray-400 text-sm"><%= member.bio %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
