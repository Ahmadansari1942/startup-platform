<%- contentFor('body') %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- Background Elements -->
    <div class="absolute inset-0 hero-gradient opacity-10 dark:opacity-5"></div>
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    
    <!-- Floating shapes -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary-400 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse-slow"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-secondary-400 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-8 left-1/2 w-72 h-72 bg-purple-400 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse-slow" style="animation-delay: 4s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-sm font-medium mb-8 animate-fade-in">
            <span class="flex h-2 w-2 rounded-full bg-primary-500 mr-2 animate-pulse"></span>
            🚀 Now with AI-powered analytics
        </div>

        <h1 class="text-5xl md:text-7xl font-heading font-bold mb-6 leading-tight animate-slide-up">
            Build Your <span class="gradient-text">Dream Startup</span><br>
            With Powerful Tools
        </h1>

        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-10 max-w-3xl mx-auto animate-slide-up" style="animation-delay: 0.1s;">
            All-in-one platform to launch, manage, and scale your business. 
            Join <span class="font-semibold text-primary-600">10,000+</span> founders worldwide.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s;">
            <a href="/auth/register" class="w-full sm:w-auto bg-gradient-to-r from-primary-600 to-secondary-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:shadow-xl hover:shadow-primary-500/30 transform hover:-translate-y-1 transition-all btn-shine flex items-center justify-center">
                Start Free Trial
                <i class="fas fa-arrow-right ml-2"></i>
            </a>
            <a href="#demo" class="w-full sm:w-auto bg-white dark:bg-dark-card text-gray-700 dark:text-gray-200 px-8 py-4 rounded-full font-semibold text-lg border-2 border-gray-200 dark:border-gray-700 hover:border-primary-500 dark:hover:border-primary-500 transition-all flex items-center justify-center group">
                <i class="fas fa-play-circle mr-2 text-primary-500 group-hover:scale-110 transition-transform"></i>
                Watch Demo
            </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto animate-fade-in" style="animation-delay: 0.4s;">
            <div class="text-center">
                <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">10k+</div>
                <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Active Users</div>
            </div>
            <div class="text-center">
                <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">500+</div>
                <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Startups Launched</div>
            </div>
            <div class="text-center">
                <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">99.9%</div>
                <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Uptime</div>
            </div>
            <div class="text-center">
                <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">24/7</div>
                <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">Support</div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
        <i class="fas fa-chevron-down text-2xl text-gray-400"></i>
    </div>
</section>

<!-- Features Section -->
<section class="py-24 bg-white dark:bg-dark-card relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4">Everything You Need to <span class="gradient-text">Succeed</span></h2>
            <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">Powerful features designed to help you build, launch, and scale your startup faster than ever.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Feature 1 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-chart-line text-2xl text-primary-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Advanced Analytics</h3>
                <p class="text-gray-600 dark:text-gray-400">Real-time insights into your business metrics with AI-powered predictions and recommendations.</p>
            </div>

            <!-- Feature 2 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-secondary-100 dark:bg-secondary-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-users text-2xl text-secondary-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Team Collaboration</h3>
                <p class="text-gray-600 dark:text-gray-400">Work seamlessly with your team. Share files, assign tasks, and track progress in real-time.</p>
            </div>

            <!-- Feature 3 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-shield-alt text-2xl text-green-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Enterprise Security</h3>
                <p class="text-gray-600 dark:text-gray-400">Bank-grade encryption, SSO, 2FA, and compliance with SOC2, GDPR, and HIPAA standards.</p>
            </div>

            <!-- Feature 4 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-bolt text-2xl text-orange-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Lightning Fast</h3>
                <p class="text-gray-600 dark:text-gray-400">Optimized performance with global CDN, edge caching, and 99.99% uptime guarantee.</p>
            </div>

            <!-- Feature 5 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-plug text-2xl text-purple-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">100+ Integrations</h3>
                <p class="text-gray-600 dark:text-gray-400">Connect with Slack, GitHub, Stripe, Salesforce, and all your favorite tools seamlessly.</p>
            </div>

            <!-- Feature 6 -->
            <div class="group p-8 bg-gray-50 dark:bg-dark-bg rounded-2xl hover-card border border-gray-100 dark:border-gray-700">
                <div class="w-14 h-14 bg-pink-100 dark:bg-pink-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fas fa-headset text-2xl text-pink-600"></i>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">24/7 Support</h3>
                <p class="text-gray-600 dark:text-gray-400">Get help whenever you need it. Our expert team is available round the clock via chat, email, and phone.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-primary-600 to-secondary-600"></div>
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-white mb-6">Ready to Launch Your Startup?</h2>
        <p class="text-xl text-white/90 mb-10">Join thousands of successful founders. Start your free 14-day trial today. No credit card required.</p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/auth/register" class="w-full sm:w-auto bg-white text-primary-600 px-8 py-4 rounded-full font-bold text-lg hover:shadow-xl transform hover:-translate-y-1 transition-all">
                Get Started Free
            </a>
            <a href="/contact" class="w-full sm:w-auto bg-transparent border-2 border-white text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-primary-600 transition-all">
                Talk to Sales
            </a>
        </div>
        
        <p class="mt-6 text-white/70 text-sm">Trusted by teams at Google, Microsoft, Airbnb, and more</p>
    </div>
</section>
