{
  "name": "startup-platform-mock",
  "version": "1.0.0",
  "description": "Startup Platform with Mock Data - No Database Required",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/style.css --watch",
    "build:css:prod": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/style.css --minify"
  },
  "keywords": ["nodejs", "express", "mock-data", "dashboard", "saas"],
  "author": "Ahmad Ansari",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.3.5"
  }
}
