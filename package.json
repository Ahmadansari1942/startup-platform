{
  "name": "startup-platform",
  "version": "1.0.0",
  "description": "Production-ready Node.js SaaS Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/style.css --watch",
    "build:css:prod": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/style.css --minify",
    "test": "jest",
    "docker:build": "docker build -t startup-platform .",
    "docker:run": "docker run -p 3000:3000 --env-file .env startup-platform"
  },
  "keywords": ["nodejs", "express", "mongodb", "docker", "saas"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "mongoose": "^8.0.0",
    "express-session": "^1.17.3",
    "connect-mongo": "^5.1.0",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-flash": "^0.0.2",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "method-override": "^3.0.0",
    "moment": "^2.29.4",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.3.5",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
